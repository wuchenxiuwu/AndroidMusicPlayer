<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 基础应用主题：赛博朋克紫+霓虹青，继承 Material3 深色无标题栏主题 -->
    <style name="Theme.AndroidMusicPlayer" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- 主色调 -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/black</item>

        <!-- 次色调 -->
        <item name="colorSecondary">@color/green_200</item>
        <item name="colorSecondaryVariant">@color/green_500</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- 背景/表面 -->
        <item name="android:colorBackground">@color/black</item>
        <item name="colorSurface">@color/dark_gray</item>
        <item name="colorOnSurface">@color/white</item>

        <!-- 错误色 -->
        <item name="colorError">@color/neon_pink</item>
        <item name="colorOnError">@color/black</item>

        <!-- 状态栏和导航栏融入背景 -->
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>
    </style>

    <!-- 无标题栏变体（直接继承基础主题） -->
    <style name="Theme.AndroidMusicPlayer.NoActionBar" parent="Theme.AndroidMusicPlayer" />
</resources>
